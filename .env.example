# ── Kachow — environment configuration ───────────────────────────────────────
# Copy this file to `.env` and fill in the values. NEVER commit the real `.env`.
# (Only the variable NAMES are meaningful here; the values are placeholders.)

# ── App ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://assistant.example.com
# 32-byte base64 key used to encrypt OAuth refresh tokens at rest (libsodium
# secretbox). Keep it STABLE forever — rotating it breaks stored tokens.
# Generate: php -r "echo base64_encode(random_bytes(32)), PHP_EOL;"
APP_ENCRYPTION_KEY=

# ── Database (MySQL / MariaDB, utf8mb4) ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=kachow
DB_USER=
DB_PASS=

# ── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Optional comma-separated fallbacks, cheapest last (used for light tasks like
# titling conversations and generating home-screen starters).
GEMINI_FALLBACK_MODELS=
GEMINI_TEMPERATURE=0.7

# ── Google OAuth (Calendar + Gmail) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://assistant.example.com/api/google-callback.php

# ── Microsoft OAuth (Outlook / Hotmail via Graph) ────────────────────────────
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=https://assistant.example.com/api/outlook-callback.php

# ── Email sending ────────────────────────────────────────────────────────────
# The assistant always drafts + waits for confirmation; this is the global lock.
EMAIL_SEND_ENABLED=false

# Outbound system mail (invites, notifications)
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=Kachow

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate a key pair once and keep it stable. VAPID_SUBJECT is a contact mailto.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ── Discogs (vinyl collection enrichment) ────────────────────────────────────
DISCOGS_TOKEN=
DISCOGS_USER_AGENT=Kachow/1.0
